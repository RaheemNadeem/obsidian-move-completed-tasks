{
  "name": "move-completed-tasks",
  "version": "1.0.0",
  "description": "Automatically move completed checklist items to the bottom of their checklist.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "tasks",
    "checklist",
    "todo"
  ],
  "author": "Mohammed Raheem",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@types/node": "^20.11.30",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.2",
    "jsdom": "^24.1.3",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.4.5"
  }
}
